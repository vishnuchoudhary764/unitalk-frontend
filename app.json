{
  "expo": {
    "name": "uniTalk",
    "owner": "unitalk",
    "slug": "uniTalk",
    "scheme": "unitalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/uniTalk.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/uniTalk.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/uniTalk.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.unitalk.uniTalk",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true
    },
    "web": {
      "favicon": "./src/assets/uniTalk.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b673ac60-5533-440d-ac4a-fc0c55a9d3e0"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
