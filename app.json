{
  "expo": {
    "name": "uniTalk",
    "slug": "uniTalk",
    "scheme": "unitalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/uniTalk.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/uniTalk.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/uniTalk.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vishnu_choudhary764.uniTalk",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true
    },
    "web": {
      "favicon": "./src/assets/uniTalk.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "162c098e-3610-4def-af0f-8994b8554512"
      }
    }
  }
}